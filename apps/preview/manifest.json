{
  "id": "io.brainstorm.preview",
  "name": "Preview",
  "version": "0.1.0",
  "sdk": "1",
  "description": "Quick-Look-style multi-format media previewer. Thin sandboxed shell whose render-pane embeds a per-kind renderer module (image / video / audio / text / markdown / code / pdf). The inspector edits the previewed file's vault properties and comments.",
  "icon": "icon.svg",
  "i18n": { "source": "en", "locales": ["en", "es"] },
  "entry": "dist/index.html",
  "capabilities": [
    "storage.kv",
    "entities.read:*",
    "entities.write:brainstorm/File/v1",
    "entities.write:brainstorm/Comment/v1",
    "intents.dispatch:open"
  ],
  "registrations": {
    "openers": [
      { "kind": "secondary", "mime": "image/png" },
      { "kind": "secondary", "mime": "image/jpeg" },
      { "kind": "secondary", "mime": "image/gif" },
      { "kind": "secondary", "mime": "image/webp" },
      { "kind": "secondary", "mime": "image/avif" },
      { "kind": "secondary", "mime": "image/svg+xml" },
      { "kind": "secondary", "mime": "video/mp4" },
      { "kind": "secondary", "mime": "video/webm" },
      { "kind": "secondary", "mime": "video/quicktime" },
      { "kind": "secondary", "mime": "audio/mpeg" },
      { "kind": "secondary", "mime": "audio/wav" },
      { "kind": "secondary", "mime": "audio/ogg" },
      { "kind": "secondary", "mime": "audio/flac" },
      { "kind": "secondary", "mime": "text/plain" },
      { "kind": "secondary", "mime": "text/markdown" },
      { "kind": "primary", "mime": "application/pdf" },
      { "kind": "secondary", "mime": "model/gltf-binary" },
      { "kind": "secondary", "mime": "model/gltf+json" },
      { "kind": "secondary", "mime": "model/obj" },
      { "kind": "secondary", "mime": "image/x-canon-cr2" },
      { "kind": "secondary", "mime": "image/x-nikon-nef" },
      { "kind": "secondary", "mime": "image/x-sony-arw" },
      { "kind": "secondary", "mime": "image/x-adobe-dng" },
      { "kind": "secondary", "mime": "image/x-olympus-orf" },
      { "kind": "secondary", "mime": "image/x-panasonic-rw2" },
      { "kind": "secondary", "mime": "image/x-fuji-raf" },
      {
        "kind": "secondary",
        "mime": "application/vnd.openxmlformats-officedocument.wordprocessingml.document"
      },
      {
        "kind": "secondary",
        "mime": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
      },
      {
        "kind": "secondary",
        "mime": "application/vnd.openxmlformats-officedocument.presentationml.presentation"
      },
      { "kind": "secondary", "mime": "image/heic" },
      { "kind": "secondary", "mime": "image/heif" }
    ],
    "intents": [
      { "verb": "open", "mime": "image/png", "priority": "secondary" },
      { "verb": "open", "mime": "image/jpeg", "priority": "secondary" },
      { "verb": "open", "mime": "image/gif", "priority": "secondary" },
