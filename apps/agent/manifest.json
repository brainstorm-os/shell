{
  "id": "io.brainstorm.agent",
  "name": "Agent",
  "version": "0.2.0",
  "sdk": "1",
  "description": "Conversational AI workspace \u2014 chat over a local model, grounded in your vault. Intents as tools, cited answers, and save-as-automation land in later rungs.",
  "icon": "icon.svg",
  "i18n": {
    "source": "en",
    "locales": ["en", "es"]
  },
  "entry": "dist/index.html",
  "capabilities": [
    "storage.kv",
    "ai.use",
    "ai.provider:ollama",
    "ai.provider:anthropic",
    "ai.provider:openai",
    "ai.provider:glm",
    "ai.provider:gemini",
    "search.read",
    "search.hybrid",
    "platform.read",
    "entities.read:*",
    "entities.write:brainstorm/Conversation/v1",
    "entities.write:brainstorm/Message/v1",
    "entities.write:brainstorm/Memory/v1",
    "entities.write:brainstorm/Trigger/v1",
    "entities.write:brainstorm/Workflow/v1",
    "intents.dispatch:open",
    "intents.dispatch:insert"
  ],
  "registrations": {
    "entityTypes": [
      {
        "id": "brainstorm/Conversation/v1",
        "schemaUrl": "https://brainstorm.io/schemas/conversation/conversation/v1.json",
        "schema": {
          "type": "object",
          "required": ["title", "memoryMode"],
          "properties": {
            "title": {
              "type": "string"
            },
            "memoryMode": {
              "type": "string",
              "enum": ["per-conversation", "long-term"]
            },
            "provider": {
              "type": "string"
            },
            "model": {
              "type": "string"
            },
            "toolGrants": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "tokenBudget": {
              "type": "number"
            },
            "tokensSpent": {
              "type": "number"
            },
            "costCents": {
              "type": "number"
            },
            "tags": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "participants": {
              "type": "array",
              "items": {
                "type": "object"
              }
            }
          }
        }
      },
      {
        "id": "brainstorm/Message/v1",
        "schemaUrl": "https://brainstorm.io/schemas/conversation/message/v1.json",
        "schema": {
          "type": "object",
          "required": ["conversation", "role", "body", "createdAt"],
          "properties": {
            "conversation": {
              "type": "string"
            },
            "role": {
              "type": "string",
              "enum": ["system", "user", "assistant", "tool"]
            },
            "body": {
              "type": "string"
            },
            "sender": {
              "type": "object"
            },
            "citations": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "toolCalls": {
              "type": "array"
            },
            "aiProvenance": {
              "type": "object"
            },
            "createdAt": {
              "type": "string"
            },
            "seq": {
              "type": "number"
            }
          }
        }
      },
      {
        "id": "brainstorm/Memory/v1",
        "schemaUrl": "https://brainstorm.io/schemas/conversation/memory/v1.json",
        "schema": {
          "type": "object",
          "required": ["text", "createdAt"],
          "properties": {
            "text": {
              "type": "string"
            },
            "createdAt": {
              "type": "string"
            },
            "updatedAt": {
              "type": "string"
            },
            "source": {
              "type": "string"
            }
          }
        }
      }
    ],
    "openers": [
      {
        "kind": "primary",
        "entityType": "brainstorm/Conversation/v1"
      }
    ],
    "widgets": [
      {
        "id": "recent-conversations",
        "name": "Conversations",
        "size": "medium"
      }
    ],
    "intents": [
      {
        "verb": "open",
        "entityType": "brainstorm/Conversation/v1",
        "priority": "primary"
      },
      {
        "verb": "process",
        "kind": "summarize",
        "label": "Summarize with the agent",
        "icon": "sparkle",
        "group": "actions",
        "priority": "secondary"
      },
      {
        "verb": "process",
        "kind": "ask",
        "label": "Ask the agent about this",
        "icon": "sparkle",
        "group": "actions",
        "priority": "secondary"
      }
    ]
  }
}
