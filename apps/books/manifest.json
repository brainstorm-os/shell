{
  "id": "io.brainstorm.books",
  "name": "Books",
  "version": "0.1.0",
  "sdk": "1",
  "description": "EPUB and PDF reader with highlights as first-class entities, typography controls, and an in-vault library.",
  "icon": "icon.svg",
  "entry": "dist/index.html",
  "capabilities": [
    "storage.kv",
    "entities.read:brainstorm/Book/v1",
    "entities.write:brainstorm/Book/v1",
    "entities.read:brainstorm/Highlight/v1",
    "entities.write:brainstorm/Highlight/v1",
    "entities.read:brainstorm/File/v1",
    "entities.write:brainstorm/File/v1",
    "entities.write:brainstorm/Comment/v1",
    "files.read",
    "intents.dispatch:open",
    "blocks.provide:io.brainstorm.books/embedded-highlight"
  ],
  "registrations": {
    "widgets": [{ "id": "currently-reading", "name": "Currently Reading", "size": "medium" }],
    "entityTypes": [
      {
        "id": "brainstorm/Book/v1",
        "schemaUrl": "https://brainstorm.io/schemas/books/book/v1.json",
        "schema": {
          "type": "object",
          "required": ["id", "name", "format", "spineLength", "reading", "createdAt", "updatedAt"],
          "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" },
            "icon": { "type": ["object", "null"] },
            "format": { "type": "string", "enum": ["epub", "pdf"] },
            "author": { "type": "string" },
            "fileId": { "type": ["string", "null"] },
            "spineLength": { "type": "number" },
            "reading": {
              "type": "object",
              "required": ["position", "progress", "lastReadAt"],
              "properties": {
                "position": { "type": ["object", "null"] },
                "progress": { "type": "number" },
                "lastReadAt": { "type": ["number", "null"] }
              }
            },
            "createdAt": { "type": "number" },
            "updatedAt": { "type": "number" }
          }
        }
      },
      {
        "id": "brainstorm/Highlight/v1",
        "schemaUrl": "https://brainstorm.io/schemas/books/highlight/v1.json",
        "schema": {
          "type": "object",
          "required": ["id", "bookId", "anchor", "color", "quote", "createdAt", "updatedAt"],
          "properties": {
            "id": { "type": "string" },
            "bookId": { "type": "string" },
            "anchor": {
              "type": "object",
              "required": ["start", "end"],
              "properties": {
                "start": { "type": "object" },
                "end": { "type": "object" }
              }
            },
            "color": {
              "type": "string",
              "enum": ["yellow", "green", "blue", "pink", "purple"]
            },
            "quote": { "type": "string" },
            "note": { "type": "string" },
            "createdAt": { "type": "number" },
            "updatedAt": { "type": "number" }
          }
        }
      }
    ],
    "openers": [
      { "kind": "primary", "entityType": "brainstorm/Book/v1" },
      { "kind": "secondary", "mime": "application/pdf" }
    ],
    "intents": [
      { "verb": "open", "entityType": "brainstorm/Book/v1", "priority": "primary" },
      { "verb": "open", "mime": "application/pdf", "priority": "secondary" }
    ],
    "blocks": [
      {
        "id": "io.brainstorm.books/embedded-highlight",
        "name": "Embedded highlight",
        "entityTypes": ["brainstorm/Highlight/v1"]
      }
    ]
  }
}
