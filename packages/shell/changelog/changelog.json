    {
      "version": "0.4.0",
      "date": "2026-07-12",
      "icon": "👥",
      "title": "See who's here",
      "summary": "Live presence — when you share a board or a note, you now see your collaborators' cursors and avatars in real time. Plus a per-site trust switch for the browser and an instant light/dark shell.",
      "body": [
        {
          "kind": "h1",
          "text": "Live presence"
        },
        {
          "kind": "li",
          "text": [
            {
              "text": "Whiteboard",
              "marks": ["bold"]
            },
            {
              "text": " — everyone on a shared board sees each other's "
            },
            {
              "text": "cursors and selection",
              "marks": ["highlight"]
            },
            {
              "text": " move live, across devices."
            }
          ]
        },
        {
          "kind": "li",
          "text": [
            {
              "text": "Notes",
              "marks": ["bold"]
            },
            {
              "text": " — an "
            },
            {
              "text": "avatar stack",
              "marks": ["highlight"]
            },
            {
              "text": " in the header shows who else is viewing a note with you."
            }
          ]
        },
        {
          "kind": "p",
          "text": "Presence is display-only and end-to-end encrypted like everything else — it rides the same sealed sync channel and grants no access on its own."
        },
        {
          "kind": "h1",
          "text": "Browser"
        },
