{
  "name": "@brainstorm-os/relay-server",
  "version": "0.0.1",
  "description": "A blind, forward-only WebSocket relay — fan-out of end-to-end-encrypted frames the server never decodes.",
  "keywords": [
    "relay",
    "websocket",
    "e2ee",
    "end-to-end-encryption",
    "fan-out",
    "pubsub",
    "blind-relay",
    "sync",
    "bun"
  ],
  "license": "MIT",
  "homepage": "https://github.com/brainstorm-os/relay-server#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brainstorm-os/relay-server.git"
  },
  "bugs": {
    "url": "https://github.com/brainstorm-os/relay-server/issues"
  },
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "sideEffects": false,
  "bin": {
    "brainstorm-relay": "bin/relay.ts"
  },
  "files": ["dist", "bin", "README.md", "LICENSE"],
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "bun --bun run bin/relay.ts",
    "build": "tsup src/index.ts --format esm --dts --clean --outDir dist --tsconfig tsconfig.build.json && node ../../scripts/prepare-publish.mjs relay-server",
    "test": "bun --bun vitest run",
    "prepublishOnly": "bun run build"
  }
}
