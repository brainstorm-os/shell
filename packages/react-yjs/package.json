{
  "name": "@brainstorm-os/react-yjs",
  "version": "0.0.1",
  "description": "React hooks bridging Yjs CRDT state into React components.",
  "keywords": [
    "yjs",
    "react",
    "crdt",
    "hooks",
    "collaborative",
    "realtime",
    "y-doc",
    "awareness",
    "presence",
    "useSyncExternalStore"
  ],
  "license": "MIT",
  "homepage": "https://github.com/brainstorm-os/react-yjs#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brainstorm-os/react-yjs.git"
  },
  "bugs": {
    "url": "https://github.com/brainstorm-os/react-yjs/issues"
  },
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "sideEffects": false,
  "files": ["dist", "README.md", "LICENSE"],
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --outDir dist --tsconfig tsconfig.build.json && node ../../scripts/prepare-publish.mjs react-yjs",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "yjs": "^13.6.30"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "yjs": "^13.6.30"
  }
}
