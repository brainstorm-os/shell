{
  "name": "@brainstorm-os/react-yjs",
  "version": "0.0.1",
  "description": "React hooks bridging Yjs CRDT state into React components.",
  "license": "MIT",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --outDir dist --tsconfig tsconfig.build.json && node ../../scripts/prepare-publish.mjs react-yjs",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@brainstorm-os/sdk-types": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "yjs": "^13.6.30"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "yjs": "^13.6.30"
  }
}
